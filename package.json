{
  "name": "bishopdgreat-portfolio",
  "private": true,
  "version": "0.0.0",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "type": "module",
  "scripts": {
    "predev": "npm run project:validate",
    "dev": "vite",
    "prebuild": "npm run project:validate",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "test": "vitest run",
    "test:watch": "vitest",
    "project:add": "node scripts/add-project.mjs",
    "project:validate": "node scripts/validate-projects.mjs",
    "project:publish": "node scripts/publish-project.mjs",
    "spotify:authorize": "node --env-file-if-exists=.env.local scripts/spotify-auth.mjs",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "check": "npm run test && npm run lint && npm run build && npm run scan:secrets && npm audit --audit-level=high",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
